{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "env": {
    "NODE_ENV": "production"
  },
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://www.gruhaconstruction.com/:path*",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "gruhaconstruction.com"
        }
      ]
    }
  ]
}